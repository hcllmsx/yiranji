{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "以苒纪",
  "version": "26.7.2",
  "identifier": "com.yiranji.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "以苒纪",
        "width": 1104,
        "height": 621,
        "minWidth": 1104,
        "minHeight": 621,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "visible": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "outputName": "以苒纪",
        "languages": [
          "English",
          "SimplifiedChinese"
        ]
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
